{
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "live-server": "^1.2.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  },
  "name": "early-careers-jet",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "watch:server": "nodemon --watch src/server --ext ts --exec ts-node src/server/server.ts",
    "watch:client": "esbuild src/client/client.ts --bundle --outfile=public/bundle.js --format=esm --target=esnext --watch",
    "serve": "live-server public --port=8080 --proxy=/api:http://localhost:3000 --open",
    "dev": "concurrently \"npm run watch:client\" \"npm run watch:server\" \"npm run serve\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1"
  }
}
